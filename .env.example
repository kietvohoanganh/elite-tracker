# Default false uses the local mock parser so the review UI can be tested without a backend.
# Set to true when a backend or serverless endpoint is available at /api/parse-workout-image.
# Keep OCR or AI provider API keys on the backend only.
VITE_USE_REAL_IMAGE_PARSER=false

# In local dev, a missing parser endpoint falls back to mock data unless this is true.
VITE_DISABLE_IMAGE_PARSER_MOCK=false
